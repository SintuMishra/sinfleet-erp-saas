NODE_ENV=development
PORT=5001
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sinfleet_erp_db?schema=public
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
SUPER_ADMIN_NAME="SinSoftware Super Admin"
SUPER_ADMIN_EMAIL=admin@sinsoftware.in
SUPER_ADMIN_PASSWORD=change-this-before-seeding
DEMO_SUPER_ADMIN_EMAIL=superadmin@sinfleet.demo
DEMO_SUPER_ADMIN_PASSWORD=
DEMO_COMPANY_ADMIN_PASSWORD=
DEMO_RESET=false
REDIS_URL=redis://localhost:6379
