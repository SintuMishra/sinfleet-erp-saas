NODE_ENV=development

# Frontend
NEXT_PUBLIC_APP_NAME="SinFleet ERP"
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001/api

# Backend
PORT=5001
API_PREFIX=/api
CORS_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sinfleet_erp_db?schema=public

# Secure seed values for local/first deployment only.
# Replace before running `npm run db:seed`.
SUPER_ADMIN_NAME="SinSoftware Super Admin"
SUPER_ADMIN_EMAIL=admin@sinsoftware.in
SUPER_ADMIN_PASSWORD=change-this-before-seeding

# Optional demo seed credentials for `npm run db:seed:demo`.
# Leave passwords blank to generate temporary values printed by the seed command.
DEMO_SUPER_ADMIN_EMAIL=superadmin@sinfleet.demo
DEMO_SUPER_ADMIN_PASSWORD=
DEMO_COMPANY_ADMIN_PASSWORD=
DEMO_RESET=false

# Future services
REDIS_URL=redis://localhost:6379
GPS_PROVIDER_API_KEY=
OCR_PROVIDER_API_KEY=
AI_ANALYTICS_API_KEY=
WHATSAPP_PROVIDER_TOKEN=
